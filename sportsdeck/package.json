{
  "name": "sportsdeck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cron:matches": "node scripts/cron/fetch-matches.cjs",
    "cron:sentiment": "node scripts/cron/analyze-sentiments.cjs",
    "cron:run": "npm run cron:matches && npm run cron:sentiment",
    "lint": "eslint",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:server": "next dev",
    "test:db:migrate": "prisma migrate deploy",
    "test:db:reset": "prisma migrate reset --force && prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:reset": "npx prisma migrate reset --force && npx prisma generate",
    "vercel:deploy": "bash deploy-vercel.sh",
    "vercel:setup": "bash vercel-setup.sh",
    "vercel:secrets": "bash vercel-setup.sh",
    "postinstall": "node setup-prisma.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@babel/runtime": "^7.28.6",
    "@huggingface/inference": "^4.13.13",
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.13.6",
    "babel-jest": "^30.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
